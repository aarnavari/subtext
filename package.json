{
  "name": "pinkfontbtw",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron": "electron electron/main.js",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\"",
    "build": "next build",
    "start": "next start",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.pinkfontbtw.app",
    "productName": "pinkfontbtw",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"]
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}